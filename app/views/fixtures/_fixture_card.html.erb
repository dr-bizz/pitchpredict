<%# locals: (fixture:, prediction: nil, just_saved: false) -%>
<% prediction ||= Prediction.new(fixture: fixture) %>
<%= turbo_frame_tag dom_id(fixture, :prediction) do %>
  <article class="card card-pad flex h-full flex-col gap-4">
    <header class="flex items-start justify-between gap-2">
      <div class="text-xs text-charcoal/60">
        <p class="font-medium text-charcoal/80">
          <time datetime="<%= fixture.kickoff_at.iso8601 %>"><%= kickoff_label(fixture) %></time>
        </p>
        <p><%= fixture.stadium.name %> · <%= fixture.stadium.city %></p>
      </div>
      <div class="flex shrink-0 items-center gap-1.5">
        <% if fixture.live? %>
          <span class="pill-live">Live</span>
        <% end %>
        <% if fixture.finished? && prediction.persisted? && prediction.points_awarded.present? %>
          <span class="pill-points">+<%= prediction.points_awarded %> pts</span>
        <% elsif fixture.finished? && !prediction.persisted? %>
          <span class="pill-muted">No prediction</span>
        <% elsif prediction.persisted? %>
          <span class="pill-predicted">Predicted</span>
        <% end %>
        <% if fixture.locked? && !fixture.finished? %>
          <svg class="h-4 w-4 text-charcoal/40" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z" clip-rule="evenodd" />
          </svg>
          <span class="sr-only">Locked</span>
        <% end %>
      </div>
    </header>

    <div class="flex items-center justify-between gap-3">
      <div class="flex min-w-0 flex-1 items-center gap-2">
        <span class="text-2xl leading-none" aria-hidden="true"><%= fixture.home_team.flag_emoji %></span>
        <span class="truncate text-sm font-semibold text-charcoal sm:text-base"><%= fixture.home_team.name %></span>
      </div>
      <% if fixture.finished? %>
        <div class="shrink-0 text-xl font-bold tabular-nums text-charcoal">
          <%= fixture.home_score %> – <%= fixture.away_score %>
        </div>
      <% else %>
        <span class="shrink-0 text-xs font-semibold uppercase tracking-wide text-charcoal/40">vs</span>
      <% end %>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
        <span class="truncate text-right text-sm font-semibold text-charcoal sm:text-base"><%= fixture.away_team.name %></span>
        <span class="text-2xl leading-none" aria-hidden="true"><%= fixture.away_team.flag_emoji %></span>
      </div>
    </div>

    <% if fixture.locked? %>
      <div class="mt-auto flex flex-col items-center gap-1.5">
        <% if prediction.errors.any? %>
          <%# A save raced past kickoff: explain why it was rejected. %>
          <p class="w-full rounded-lg bg-red-50 px-3 py-2 text-center text-xs font-medium text-red-700" role="alert">
            <%= prediction.errors.full_messages.to_sentence %>
          </p>
        <% end %>
        <% if prediction.persisted? %>
          <div class="flex items-center justify-center gap-3 opacity-60">
            <%# *_in_database so a just-rejected (dirty) update still shows the saved pick. %>
            <input type="number" class="score-input" value="<%= prediction.home_score_in_database %>" disabled
                   aria-label="Your predicted <%= fixture.home_team.name %> goals">
            <span class="font-semibold text-charcoal/40">:</span>
            <input type="number" class="score-input" value="<%= prediction.away_score_in_database %>" disabled
                   aria-label="Your predicted <%= fixture.away_team.name %> goals">
          </div>
          <p class="text-xs text-charcoal/50">
            <%= fixture.finished? ? "Your prediction" : "Your prediction · locked at kickoff" %>
          </p>
        <% else %>
          <p class="text-xs text-charcoal/50">Predictions closed at kickoff.</p>
        <% end %>
      </div>
    <% else %>
      <%= form_with model: prediction, url: fixture_prediction_path(fixture), class: "mt-auto flex flex-col gap-3" do |form| %>
        <% if prediction.errors.any? %>
          <p class="rounded-lg bg-red-50 px-3 py-2 text-xs font-medium text-red-700" role="alert">
            <%= prediction.errors.full_messages.to_sentence %>
          </p>
        <% end %>

        <div class="flex items-center justify-center gap-3">
          <div class="flex items-center gap-1.5" data-controller="stepper">
            <button type="button" data-action="stepper#decrement"
                    class="grid h-8 w-8 select-none place-items-center rounded-full bg-surface text-base font-bold leading-none text-charcoal/70 ring-1 ring-charcoal/10 hover:bg-pitch/10 hover:text-pitch"
                    aria-label="Decrease <%= fixture.home_team.name %> goals">−</button>
            <%= form.number_field :home_score, in: 0..20, step: 1, required: true,
                                  inputmode: "numeric", class: "score-input",
                                  data: { stepper_target: "input" },
                                  aria: { label: "#{fixture.home_team.name} goals" } %>
            <button type="button" data-action="stepper#increment"
                    class="grid h-8 w-8 select-none place-items-center rounded-full bg-surface text-base font-bold leading-none text-charcoal/70 ring-1 ring-charcoal/10 hover:bg-pitch/10 hover:text-pitch"
                    aria-label="Increase <%= fixture.home_team.name %> goals">+</button>
          </div>

          <span class="font-semibold text-charcoal/40">:</span>

          <div class="flex items-center gap-1.5" data-controller="stepper">
            <button type="button" data-action="stepper#decrement"
                    class="grid h-8 w-8 select-none place-items-center rounded-full bg-surface text-base font-bold leading-none text-charcoal/70 ring-1 ring-charcoal/10 hover:bg-pitch/10 hover:text-pitch"
                    aria-label="Decrease <%= fixture.away_team.name %> goals">−</button>
            <%= form.number_field :away_score, in: 0..20, step: 1, required: true,
                                  inputmode: "numeric", class: "score-input",
                                  data: { stepper_target: "input" },
                                  aria: { label: "#{fixture.away_team.name} goals" } %>
            <button type="button" data-action="stepper#increment"
                    class="grid h-8 w-8 select-none place-items-center rounded-full bg-surface text-base font-bold leading-none text-charcoal/70 ring-1 ring-charcoal/10 hover:bg-pitch/10 hover:text-pitch"
                    aria-label="Increase <%= fixture.away_team.name %> goals">+</button>
          </div>
        </div>

        <div class="flex items-center justify-center gap-2">
          <%= form.submit prediction.persisted? ? "Update prediction" : "Save prediction", class: "btn-primary" %>
          <% if just_saved %>
            <span class="text-xs font-semibold text-pitch" role="status">Saved ✓</span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </article>
<% end %>
