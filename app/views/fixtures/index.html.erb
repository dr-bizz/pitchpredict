<% content_for :title, "Predictions" %>

<%# Live updates: ScoreFixtureJob broadcasts a refresh to "results" after
    scoring, so this grid re-GETs itself and morphs in finished results. Morph
    preserves a focused input, so a player mid-prediction isn't clobbered. %>
<%= turbo_stream_from "results" %>

<div class="space-y-6">
  <header>
    <h1 class="page-title">Predictions</h1>
    <p class="mt-1 text-sm text-charcoal/60">
      Lock in your scores before kickoff — 4 pts exact, 3 pts goal difference, 2 pts outcome.
    </p>
  </header>

  <div class="space-y-2">
    <nav role="tablist" class="tabs tabs-box flex-wrap gap-1 bg-base-200 p-1" aria-label="Status">
      <% FixturesHelper::STATUS_TABS.each do |status, label| %>
        <%= link_to label, predictions_path(status: status, stage: @stage),
                    role: "tab",
                    class: "tab #{'tab-active' if status == @status}",
                    aria: { current: status == @status ? "page" : nil } %>
      <% end %>
    </nav>

    <nav role="tablist" class="tabs tabs-box flex-wrap gap-1 bg-base-200 p-1" aria-label="Stage">
      <% FixturesHelper::STAGE_TABS.each do |stage, label| %>
        <%= link_to label, predictions_path(stage: stage, status: @status),
                    role: "tab",
                    class: "tab #{'tab-active' if stage == @stage}",
                    aria: { current: stage == @stage ? "page" : nil } %>
      <% end %>
    </nav>
  </div>

  <% if @sections.empty? %>
    <div class="card bg-base-100 shadow-card rounded-2xl">
      <div class="card-body items-center text-center text-sm text-base-content/60">
        <%= empty_fixtures_message(@status) %>
      </div>
    </div>
  <% else %>
    <%# Day-grouped views split into upcoming (soonest first) then past (most
        recent first). A "Kicked off" divider marks that boundary the first time
        a past section follows an upcoming one. Stage-grouped views (Groups, a
        single knockout round) carry no past tag, so no divider appears. %>
    <% seen_upcoming = false %>
    <% rendered_divider = false %>
    <% @sections.each do |section| %>
      <% if section.past && seen_upcoming && !rendered_divider %>
        <div class="divider text-xs uppercase tracking-wide text-base-content/50">Kicked off</div>
        <% rendered_divider = true %>
      <% end %>
      <section class="space-y-3">
        <% if section.heading %>
          <h2 class="section-title"><%= section.heading %></h2>
        <% end %>
        <div class="grid gap-4 min-[851px]:grid-cols-2">
          <% section.fixtures.each do |fixture| %>
            <%= render "fixtures/fixture_card",
                       fixture: fixture,
                       prediction: @predictions_by_fixture_id[fixture.id] %>
          <% end %>
        </div>
      </section>
      <% seen_upcoming = true unless section.past %>
    <% end %>
  <% end %>
</div>
