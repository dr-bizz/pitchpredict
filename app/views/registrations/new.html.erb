<%# NOTE: Plain ERB on purpose — styling pass happens in a later stage. %>
<h1>Sign up</h1>

<%= form_with model: @user, url: registration_url do |form| %>
  <% if @user.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@user.errors.count, "error") %> prevented your account from being created:</h2>
      <ul>
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true, autofocus: true, autocomplete: "name" %>
  </div>

  <div>
    <%= form.label :email_address %>
    <%= form.email_field :email_address, required: true, autocomplete: "username" %>
  </div>

  <div>
    <%= form.label :password %>
    <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72 %>
  </div>

  <div>
    <%= form.label :password_confirmation %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
  </div>

  <div>
    <%= form.submit "Sign up" %>
  </div>
<% end %>

<p>Already have an account? <%= link_to "Sign in", new_session_path %></p>
