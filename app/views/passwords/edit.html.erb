<% content_for :title, "Set new password · PitchPredict" %>

<div class="mx-auto mt-4 max-w-md sm:mt-10">
  <%= link_to root_path, class: "mb-6 flex items-center justify-center gap-2 text-charcoal" do %>
    <%= image_tag "icon.svg", alt: "PitchPredict", class: "h-10 w-10 rounded-xl shadow-md" %>
    <span class="text-xl font-bold tracking-tight">PitchPredict</span>
  <% end %>

  <div class="card bg-base-100 shadow-md rounded-2xl">
    <div class="card-body">
      <h1 class="page-title">Set a new password</h1>
      <p class="mt-1 text-sm text-base-content/60">
        Pick something memorable — the knockout rounds are no time to be locked out.
      </p>

      <%= form_with url: password_path(params[:token]), method: :put, class: "mt-6 space-y-4" do |form| %>
        <div class="form-control">
          <%= form.label :password, "New password", class: "label-text font-medium mb-1" %>
          <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password",
                placeholder: "Enter new password", maxlength: 72, class: "input w-full" %>
        </div>

        <div class="form-control">
          <%= form.label :password_confirmation, "Confirm new password", class: "label-text font-medium mb-1" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
                placeholder: "Repeat new password", maxlength: 72, class: "input w-full" %>
        </div>

        <%= form.submit "Save new password", class: "btn btn-primary w-full" %>
      <% end %>
    </div>
  </div>

  <p class="mt-4 text-center text-sm text-base-content/60">
    <%= link_to "Back to sign in", new_session_path, class: "link link-primary font-semibold no-underline" %>
  </p>
</div>
