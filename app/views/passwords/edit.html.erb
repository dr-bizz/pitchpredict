<% content_for :title, "Set new password · PitchPredict" %>

<div class="mx-auto mt-4 max-w-md sm:mt-10">
  <div class="card card-pad">
    <h1 class="page-title">Set a new password</h1>
    <p class="mt-1 text-sm text-charcoal/60">
      Pick something memorable — the knockout rounds are no time to be locked out.
    </p>

    <%= form_with url: password_path(params[:token]), method: :put, class: "mt-6 space-y-4" do |form| %>
      <div>
        <%= form.label :password, "New password", class: "field-label" %>
        <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password",
              placeholder: "Enter new password", maxlength: 72, class: "field" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm new password", class: "field-label" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
              placeholder: "Repeat new password", maxlength: 72, class: "field" %>
      </div>

      <%= form.submit "Save new password", class: "btn-primary w-full" %>
    <% end %>
  </div>

  <p class="mt-4 text-center text-sm text-charcoal/60">
    <%= link_to "Back to sign in", new_session_path, class: "font-semibold text-pitch hover:text-pitch-dark" %>
  </p>
</div>
