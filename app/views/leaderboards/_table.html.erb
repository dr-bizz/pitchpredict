<%# Live leaderboard table.
    LIVE-UPDATE MECHANISM (morph refresh — do not break):
    - leaderboards/show.html.erb subscribes via turbo_stream_from "results".
      When a result is scored, ScoreFixtureJob calls broadcast_refresh_to("results"),
      which tells subscribers to re-GET their current URL; Turbo then morphs the
      diff in place. There is NO targeted broadcast_replace_to of this partial.
    - id="leaderboard-table" is retained ONLY so the leaderboard-highlight
      Stimulus controller can scope to this element (do not add a targeted
      broadcast back).
    - locals: rows (Array<LeaderboardService::Row>) and current_user. The server
      highlights the viewer's row when it can (no-JS fallback); the
      leaderboard-highlight controller re-applies the highlight client-side via
      each row's data-user-id and the layout's <meta name="current-user-id"> tag. %>
<% viewer = local_assigns[:current_user] %>

<div id="leaderboard-table" data-controller="leaderboard-highlight">
  <% if rows.empty? %>
    <div class="hero py-16">
      <div class="hero-content text-center">
        <div>
          <p class="text-4xl" aria-hidden="true">🏆</p>
          <h2 class="section-title mt-4">No standings yet</h2>
          <p class="mt-1 text-sm text-base-content/60">
            Make some predictions and the table will fill up once results are scored.
          </p>
        </div>
      </div>
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr class="text-xs uppercase tracking-wide text-base-content/50">
            <th scope="col">Rank</th>
            <th scope="col">Player</th>
            <th scope="col" class="text-right">Points</th>
            <th scope="col" class="hidden text-right sm:table-cell">Preds</th>
            <th scope="col" class="hidden text-right md:table-cell">Exact</th>
            <th scope="col" class="hidden text-right md:table-cell">Diff</th>
            <th scope="col" class="hidden text-right md:table-cell">Tendency</th>
          </tr>
        </thead>
        <tbody>
          <% rows.each do |row| %>
            <% mine = viewer.present? && row.user.id == viewer.id %>
            <% medal = { 1 => "🥇", 2 => "🥈", 3 => "🥉" }[row.rank] %>
            <tr data-user-id="<%= row.user.id %>" data-current-user="<%= mine %>" class="<%= "bg-pitch-light" if mine %>">
              <td>
                <% if medal %>
                  <span class="text-xl leading-none" title="Rank <%= row.rank %>"><%= medal %></span>
                  <span class="sr-only"><%= row.rank %></span>
                <% else %>
                  <span class="font-semibold tabular-nums text-base-content/60">#<%= row.rank %></span>
                <% end %>
              </td>
              <td class="font-medium">
                <div class="flex items-center gap-2.5">
                  <span class="avatar-initial h-9 w-9 text-sm <%= mine ? "avatar-initial-you" : "avatar-initial-muted" %>"><%= row.user.name.first.upcase %></span>
                  <span><%= row.user.name %></span>
                  <%# Rendered for every row (hidden) so the Stimulus controller can
                      reveal the viewer's badge after a viewer-agnostic broadcast. %>
                  <span data-you-badge class="badge badge-success badge-sm" <%= "hidden" unless mine %>>You</span>
                </div>
              </td>
              <td class="text-right">
                <span class="font-extrabold tabular-nums text-gold-dark"><%= row.total_points %></span>
                <span class="text-xs text-base-content/40">pts</span>
              </td>
              <td class="hidden text-right tabular-nums text-base-content/60 sm:table-cell"><%= row.predictions_count %></td>
              <td class="hidden text-right font-semibold tabular-nums text-pitch md:table-cell"><%= row.exact_count %></td>
              <td class="hidden text-right font-semibold tabular-nums text-teal-accent md:table-cell"><%= row.diff_count %></td>
              <td class="hidden text-right tabular-nums text-base-content/50 md:table-cell"><%= row.tendency_count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
