<%# Live leaderboard table.
    BROADCAST CONTRACT (ScoreFixtureJob — do not break):
    - the root element keeps id="leaderboard-table" so
      Turbo::StreamsChannel.broadcast_replace_to can swap it in place;
    - locals: rows (Array<LeaderboardService::Row>) and current_user, which is
      nil when rendered from the background job. The server still highlights
      the viewer's row when it can (no-JS fallback); after a broadcast the
      leaderboard-highlight Stimulus controller re-applies the highlight
      client-side via each row's data-user-id and the layout's
      <meta name="current-user-id"> tag. %>
<% viewer = local_assigns[:current_user] %>

<div id="leaderboard-table" data-controller="leaderboard-highlight">
  <% if rows.empty? %>
    <div class="hero py-16">
      <div class="hero-content text-center">
        <div>
          <p class="text-4xl" aria-hidden="true">🏆</p>
          <h2 class="section-title mt-4">No standings yet</h2>
          <p class="mt-1 text-sm text-base-content/60">
            Make some predictions and the table will fill up once results are scored.
          </p>
        </div>
      </div>
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="table table-zebra">
        <thead>
          <tr>
            <th scope="col">Rank</th>
            <th scope="col">Player</th>
            <th scope="col" class="text-right">Points</th>
            <th scope="col" class="hidden text-right sm:table-cell">Predictions</th>
            <th scope="col" class="hidden text-right md:table-cell">Exact</th>
            <th scope="col" class="hidden text-right md:table-cell">Diff</th>
            <th scope="col" class="hidden text-right md:table-cell">Tendency</th>
          </tr>
        </thead>
        <tbody>
          <% rows.each do |row| %>
            <% mine = viewer.present? && row.user.id == viewer.id %>
            <% medal = { 1 => "🥇", 2 => "🥈", 3 => "🥉" }[row.rank] %>
            <tr data-user-id="<%= row.user.id %>" data-current-user="<%= mine %>" class="<%= "bg-pitch/5" if mine %>">
              <td>
                <% if medal %>
                  <span class="text-lg leading-none" title="Rank <%= row.rank %>"><%= medal %></span>
                  <span class="sr-only"><%= row.rank %></span>
                <% else %>
                  <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-base-300 text-xs font-semibold text-base-content/70"><%= row.rank %></span>
                <% end %>
              </td>
              <td class="font-medium">
                <%= row.user.name %>
                <%# Rendered for every row (hidden) so the Stimulus controller can
                    reveal the viewer's badge after a viewer-agnostic broadcast. %>
                <span data-you-badge class="badge badge-success badge-sm ml-1.5" <%= "hidden" unless mine %>>You</span>
              </td>
              <td class="text-right">
                <span class="badge badge-warning"><%= row.total_points %> pts</span>
              </td>
              <td class="hidden text-right tabular-nums text-base-content/70 sm:table-cell"><%= row.predictions_count %></td>
              <td class="hidden text-right tabular-nums text-base-content/70 md:table-cell"><%= row.exact_count %></td>
              <td class="hidden text-right tabular-nums text-base-content/70 md:table-cell"><%= row.diff_count %></td>
              <td class="hidden text-right tabular-nums text-base-content/70 md:table-cell"><%= row.tendency_count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
