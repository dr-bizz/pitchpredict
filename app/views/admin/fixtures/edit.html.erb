<% content_for :title, "Admin · Enter result · PitchPredict" %>

<% status_badge = ->(status) {
     case status.to_s
     when "live" then "badge badge-error"
     when "finished" then "badge badge-success"
     else "badge badge-ghost"
     end
   } %>

<div class="breadcrumbs mb-4 text-sm">
  <ul>
    <li><%= link_to "Admin", admin_fixtures_path %></li>
    <li><%= link_to "Fixtures", admin_fixtures_path %></li>
    <li><%= @fixture.home_display %> vs <%= @fixture.away_display %></li>
  </ul>
</div>

<div class="mx-auto max-w-xl">
  <div class="card bg-base-100 shadow-card rounded-2xl">
    <div class="card-body">
      <div class="flex flex-wrap items-center gap-2">
        <span class="badge badge-ghost"><%= stage_label(@fixture.stage) %></span>
        <span class="<%= status_badge.call(@fixture.status) %> <%= "animate-pulse" if @fixture.live? %>"><%= @fixture.status.humanize %></span>
      </div>

      <h1 class="page-title mt-3 text-2xl font-extrabold tracking-tight">
        <%= @fixture.home_display %> <span class="font-normal text-base-content/40">vs</span> <%= @fixture.away_display %>
      </h1>
      <p class="mt-1 text-sm text-base-content/60">
        <%= kickoff_label(@fixture, style: :long) %> ·
        <%= @fixture.stadium.name %>, <%= @fixture.stadium.city %>
      </p>

      <%= form_with model: @fixture, url: admin_fixture_path(@fixture), method: :patch, class: "mt-6" do |form| %>
        <% if @fixture.errors.any? %>
          <div class="alert alert-error mb-4" role="alert">
            <div>
              <p class="font-semibold"><%= pluralize(@fixture.errors.count, "problem") %> prevented the result from being saved:</p>
              <ul class="mt-1 list-inside list-disc">
                <% @fixture.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <div class="grid grid-cols-2 gap-4">
          <div class="form-control">
            <%= form.label :home_score, @fixture.home_display, class: "label label-text font-semibold" %>
            <%= form.number_field :home_score, min: 0, step: 1, required: true, inputmode: "numeric",
                  placeholder: "0", class: "input input-bordered w-full text-center text-2xl font-bold tabular-nums" %>
          </div>
          <div class="form-control">
            <%= form.label :away_score, @fixture.away_display, class: "label label-text font-semibold" %>
            <%= form.number_field :away_score, min: 0, step: 1, required: true, inputmode: "numeric",
                  placeholder: "0", class: "input input-bordered w-full text-center text-2xl font-bold tabular-nums" %>
          </div>
        </div>

        <div class="alert alert-warning mt-4">
          <span>
            Saving marks this fixture as <strong>finished</strong>, rescores every prediction
            and pushes the new standings to the live leaderboard.
          </span>
        </div>

        <div class="mt-6 flex items-center gap-3">
          <%= form.submit @fixture.finished? ? "Update result & rescore" : "Save result & score predictions", class: "btn btn-primary" %>
          <%= link_to "Cancel", admin_fixtures_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
