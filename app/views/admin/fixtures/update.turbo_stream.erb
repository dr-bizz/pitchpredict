<% if @fixture.errors.any? %>
  <%= turbo_stream.replace dom_id(@fixture) do %>
    <%= render "form_row", fixture: @fixture %>
  <% end %>
<% else %>
  <%= turbo_stream.replace dom_id(@fixture) do %>
    <%= render "fixture_row", fixture: @fixture %>
  <% end %>
  <%= turbo_stream.prepend "admin-flash" do %>
    <div class="alert alert-success" role="status" data-controller="auto-dismiss">
      <span>Result saved: <%= @fixture.home_display %> <%= @fixture.home_score %>–<%= @fixture.away_score %> <%= @fixture.away_display %>. Predictions are being scored.</span>
    </div>
  <% end %>
<% end %>
