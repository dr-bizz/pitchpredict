<% content_for :title, "Admin · Fixtures · PitchPredict" %>

<% status_badge = ->(status) {
     case status.to_s
     when "live" then "badge badge-error"
     when "finished" then "badge badge-success"
     else "badge badge-ghost"
     end
   } %>

<div class="breadcrumbs mb-4 text-sm">
  <ul>
    <li><%= link_to "Admin", admin_fixtures_path %></li>
    <li>Fixtures</li>
  </ul>
</div>

<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
  <div>
    <h1 class="page-title">Match results</h1>
    <p class="mt-1 text-sm text-base-content/60">
      Enter a final score to finish a fixture — predictions are rescored and the leaderboard updates live.
    </p>
  </div>

  <%= form_with url: admin_fixtures_path, method: :get, class: "flex flex-wrap items-end gap-2" do |form| %>
    <div class="form-control">
      <%= form.label :stage, "Stage", class: "label label-text" %>
      <%= form.select :stage,
            options_for_select(Fixture.stages.keys.map { |s| [ stage_label(s), s ] }, @stage),
            { include_blank: "All stages" },
            class: "select select-bordered w-44" %>
    </div>
    <div class="form-control">
      <%= form.label :status, "Status", class: "label label-text" %>
      <%= form.select :status,
            options_for_select(Fixture.statuses.keys.map { |s| [ s.humanize, s ] }, @status),
            { include_blank: "All statuses" },
            class: "select select-bordered w-40" %>
    </div>
    <%= form.submit "Filter", class: "btn btn-ghost" %>
    <% if @stage || @status %>
      <%= link_to "Clear", admin_fixtures_path, class: "btn btn-ghost" %>
    <% end %>
  <% end %>
</div>

<div class="card bg-base-100 shadow-md rounded-2xl overflow-hidden">
  <div class="card-body p-0">
    <% if @fixtures.any? %>
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th>Match</th>
              <th>Kickoff</th>
              <th>Stage</th>
              <th>Status</th>
              <th class="text-center">Score</th>
              <th><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody>
            <% @fixtures.each do |fixture| %>
              <tr class="hover">
                <td>
                  <div class="font-semibold">
                    <%= fixture.home_team.name %>
                    <span class="font-normal text-base-content/40">vs</span>
                    <%= fixture.away_team.name %>
                  </div>
                  <div class="text-xs text-base-content/50"><%= fixture.stadium.name %>, <%= fixture.stadium.city %></div>
                </td>
                <td class="whitespace-nowrap text-base-content/70">
                  <%= kickoff_label(fixture) %>
                </td>
                <td><span class="badge badge-ghost"><%= stage_label(fixture.stage) %></span></td>
                <td><span class="<%= status_badge.call(fixture.status) %>"><%= fixture.status.humanize %></span></td>
                <td class="text-center font-bold tabular-nums">
                  <% if fixture.home_score && fixture.away_score %>
                    <%= fixture.home_score %>–<%= fixture.away_score %>
                  <% else %>
                    <span class="font-normal text-base-content/30">—</span>
                  <% end %>
                </td>
                <td class="text-right whitespace-nowrap">
                  <%= link_to(fixture.finished? ? "Edit result" : "Enter result",
                        edit_admin_fixture_path(fixture),
                        class: fixture.finished? ? "btn btn-ghost btn-sm" : "btn btn-primary btn-sm") %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-6 text-center text-sm text-base-content/60">
        No fixtures match this filter.
        <%= link_to "Show all fixtures", admin_fixtures_path, class: "link link-primary font-medium" %>
      </div>
    <% end %>
  </div>
</div>
