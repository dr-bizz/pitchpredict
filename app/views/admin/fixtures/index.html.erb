<% content_for :title, "Admin · Fixtures · PitchPredict" %>

<div class="space-y-6">
  <%# Toast target for inline-save confirmations (prepended via Turbo Stream).
      The admin index deliberately does NOT subscribe to "results" — a
      background morph refresh would clobber a row being edited. %>
  <div id="admin-flash" class="space-y-2"></div>

  <header class="flex flex-wrap items-center gap-3">
    <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pitch text-white shadow-card" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
    </span>
    <div>
      <h1 class="page-title text-2xl font-extrabold uppercase tracking-tight sm:text-3xl">Admin panel</h1>
      <p class="text-sm text-base-content/60">Manage fixtures · Enter results</p>
    </div>
    <%= link_to "Knockout bracket", admin_knockout_fixtures_path, class: "btn btn-outline btn-sm ml-auto" %>
  </header>

  <div class="alert alert-error rounded-2xl" role="status">
    <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-current"></span>
    <span><strong>Admin mode</strong> · Changes are published immediately.</span>
  </div>

  <%# Filter chips drive the existing stage/status GET params. %>
  <div class="space-y-3">
    <div class="flex flex-wrap items-center gap-2">
      <span class="mr-1 text-xs font-semibold uppercase tracking-wide text-base-content/50">Stage</span>
      <%= link_to "All", admin_fixtures_path(status: @status),
            class: "chip #{"chip-active" if @stage.nil?}" %>
      <% Fixture.stages.keys.each do |stage| %>
        <%= link_to stage_label(stage), admin_fixtures_path(stage: stage, status: @status),
              class: "chip #{"chip-active" if @stage == stage}" %>
      <% end %>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <span class="mr-1 text-xs font-semibold uppercase tracking-wide text-base-content/50">Status</span>
      <%= link_to "All", admin_fixtures_path(stage: @stage),
            class: "chip #{"chip-active" if @status.nil?}" %>
      <% Fixture.statuses.keys.each do |status| %>
        <%= link_to status.humanize, admin_fixtures_path(stage: @stage, status: status),
              class: "chip #{"chip-active" if @status == status}" %>
      <% end %>
    </div>
  </div>

  <div class="card bg-base-100 shadow-card rounded-2xl overflow-hidden">
    <div class="card-body p-0">
      <% if @fixtures.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr class="text-xs uppercase tracking-wide text-base-content/50">
                <th>Match</th>
                <th>Stage</th>
                <th>Status</th>
                <th class="text-center">Result</th>
                <th class="text-right"><span class="sr-only">Action</span></th>
              </tr>
            </thead>
            <tbody>
              <%= render partial: "fixture_row", collection: @fixtures, as: :fixture %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-6 text-center text-sm text-base-content/60">
          No fixtures match this filter.
          <%= link_to "Show all fixtures", admin_fixtures_path, class: "link link-primary font-medium" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
