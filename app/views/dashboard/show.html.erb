<% content_for :title, "Dashboard" %>

<%# Live updates: ScoreFixtureJob broadcasts a refresh to "results" after
    scoring, so this page re-GETs itself and morphs in the new stats/standings. %>
<%= turbo_stream_from "results" %>

<%
  # Derived view values from controller-provided data + models (read-only).
  current_user_id = Current.user.id
  first_name = Current.user.name.to_s.split(/\s+/).first.presence || Current.user.name

  my_rank = @my_row&.rank
  total_points = @total_points

  stage_labels = {
    "group" => "Group Stage", "r32" => "Round of 32", "r16" => "Round of 16",
    "qf" => "Quarter-finals", "sf" => "Semi-finals",
    "third_place" => "Third-place Play-off", "final" => "Final"
  }
  current_stage_key = Fixture.upcoming.first&.stage
  stage_label = stage_labels[current_stage_key] || "Group Stage"

  champion_team_id = @champion_pick&.team_id
%>

<div class="space-y-6">
  <%# 1. HERO %>
  <section class="hero-gradient rounded-2xl px-5 py-8 text-white shadow-card sm:px-8 sm:py-10">
    <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Hello, <%= first_name %> 👋</h1>
    <p class="mt-2 text-sm text-white/90 sm:text-base">
      <%= stage_label %> &middot; <%= pluralize(@remaining_to_predict, "match") %> remaining to predict
    </p>
    <%= link_to "Continue predicting →", predictions_path,
          class: "btn btn-secondary btn-lg mt-5 border-none text-charcoal shadow-md hover:brightness-95" %>
  </section>

  <%# 2. STAT ROW %>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="stat-tile">
      <div class="stat-tile-label">Predicted</div>
      <div class="stat-tile-value"><%= @predicted_count %>/<%= @fixtures_count %></div>
      <div class="stat-tile-sub">matches</div>
      <svg class="absolute right-4 top-4 h-7 w-7 text-pitch" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <circle cx="12" cy="12" r="9" /><circle cx="12" cy="12" r="5" /><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none" />
      </svg>
    </div>

    <div class="stat-tile">
      <div class="stat-tile-label">Points</div>
      <div class="stat-tile-value text-gold-dark"><%= total_points %></div>
      <div class="stat-tile-sub">total</div>
      <svg class="absolute right-4 top-4 h-7 w-7 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8m-4-4v4M6 4h12v3a6 6 0 0 1-12 0V4Zm0 1H4a2 2 0 0 0 0 4h2m12-4h2a2 2 0 0 1 0 4h-2" />
      </svg>
    </div>

    <div class="stat-tile">
      <div class="stat-tile-label">Rank</div>
      <div class="stat-tile-value"><%= my_rank ? "##{my_rank}" : "—" %></div>
      <div class="stat-tile-sub">global</div>
      <svg class="absolute right-4 top-4 h-7 w-7 text-pitch" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 17l6-6 4 4 7-7m0 0h-5m5 0v5" />
      </svg>
    </div>
  </div>

  <%# 3. CHAMPION PICK + TOP PLAYERS %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <%# Champion pick %>
    <section class="card rounded-2xl bg-base-100 shadow-card">
      <div class="card-body">
        <div class="flex items-start justify-between gap-2">
          <h2 class="text-lg font-bold text-charcoal">Champion Pick</h2>
          <span class="badge badge-warning border-none gap-1 font-semibold text-gold-dark">+<%= ScoringService::CHAMPION_BONUS %> pts</span>
        </div>

        <% if @champion_pick.present? %>
          <div class="mt-3 flex items-center gap-3 rounded-xl border border-gold/40 bg-gold-light/30 px-4 py-3">
            <span class="text-3xl" aria-hidden="true"><%= @champion_pick.team.flag_emoji %></span>
            <div class="min-w-0 flex-1">
              <p class="truncate font-bold text-charcoal"><%= @champion_pick.team.name %></p>
              <p class="text-xs text-gray-500">Your champion pick</p>
            </div>
            <svg class="h-7 w-7 shrink-0 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8m-4-4v4M6 4h12v3a6 6 0 0 1-12 0V4Zm0 1H4a2 2 0 0 0 0 4h2m12-4h2a2 2 0 0 1 0 4h-2" />
            </svg>
          </div>
        <% end %>

        <% if @champion_locked %>
          <div class="mt-3">
            <span class="badge badge-ghost">🔒 Picks locked — deadline passed</span>
          </div>
          <% if @champion_pick.nil? %>
            <p class="mt-3 text-sm text-gray-600">
              No champion pick was locked in before the deadline — no bonus on the line, but your
              match predictions still count for everything else.
            </p>
          <% end %>
        <% else %>
          <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-gray-500">Change pick</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <% @teams.each do |team| %>
              <%= button_to champion_pick_path, method: :patch, params: { champion_pick: { team_id: team.id } },
                    form_class: "inline-flex", data: { turbo_submits_with: "Saving…" },
                    class: "chip #{'chip-active' if team.id == champion_team_id}" do %>
                <span aria-hidden="true"><%= team.flag_emoji %></span>
                <span><%= team.name %></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <%# Top players %>
    <section class="card rounded-2xl bg-base-100 shadow-card">
      <div class="card-body">
        <div class="flex items-center justify-between gap-2">
          <h2 class="text-lg font-bold text-charcoal">Top Players</h2>
          <%= link_to "Full table →", leaderboard_path, class: "text-sm font-semibold text-pitch hover:text-pitch-dark" %>
        </div>

        <% top_players = @top_rows %>
        <% if top_players.any? %>
          <div class="mt-4 overflow-x-auto">
            <table class="table table-sm">
              <thead>
                <tr class="text-xs uppercase tracking-wide text-gray-400">
                  <th class="w-10">Rank</th>
                  <th>Player</th>
                  <th class="text-right">Pts</th>
                </tr>
              </thead>
              <tbody>
                <% medals = { 1 => "🥇", 2 => "🥈", 3 => "🥉" } %>
                <% top_players.each do |row| %>
                  <% is_you = row.user.id == current_user_id %>
                  <tr class="<%= "bg-pitch-light" if is_you %>">
                    <td class="text-lg font-bold">
                      <%= medals[row.rank] || "##{row.rank}" %>
                    </td>
                    <td>
                      <div class="flex items-center gap-2">
                        <span class="avatar-initial <%= is_you ? "avatar-initial-you" : "avatar-initial-muted" %> h-8 w-8 text-sm">
                          <%= row.user.name.to_s.first&.upcase %>
                        </span>
                        <span class="font-medium text-charcoal">
                          <%= player_predictions_link(row.user, viewer: Current.user, name: is_you ? "#{row.user.name} (you)" : row.user.name) %>
                        </span>
                      </div>
                    </td>
                    <td class="text-right font-bold text-gold-dark"><%= row.total_points %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="mt-4 text-sm text-gray-600">No players yet — be the first on the board!</p>
        <% end %>
      </div>
    </section>
  </div>

  <%# 4. HOW IT WORKS %>
  <section class="card rounded-2xl bg-base-100 shadow-card">
    <div class="card-body">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">How it works</h2>

      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="score-tile">
          <div class="score-tile-num score-tile-green">+<%= ScoringService::EXACT_POINTS %></div>
          <div class="score-tile-label">Exact score</div>
        </div>
        <div class="score-tile">
          <div class="score-tile-num score-tile-teal">+<%= ScoringService::DIFFERENCE_POINTS %></div>
          <div class="score-tile-label">Goal difference</div>
        </div>
        <div class="score-tile">
          <div class="score-tile-num score-tile-gold">+<%= ScoringService::TENDENCY_POINTS %></div>
          <div class="score-tile-label">Correct result</div>
        </div>
        <div class="score-tile">
          <div class="score-tile-num score-tile-red">+0</div>
          <div class="score-tile-label">Wrong result</div>
        </div>
      </div>

      <div role="alert" class="alert mt-4 border-none bg-gold-light/40 text-charcoal">
        <svg class="h-5 w-5 shrink-0 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8m-4-4v4M6 4h12v3a6 6 0 0 1-12 0V4Zm0 1H4a2 2 0 0 0 0 4h2m12-4h2a2 2 0 0 1 0 4h-2" />
        </svg>
        <span class="text-sm">
          <span class="font-semibold">+<%= ScoringService::CHAMPION_BONUS %> pts</span> for correct champion pick
          &middot; Predictions lock at kickoff
        </span>
      </div>
    </div>
  </section>
</div>
