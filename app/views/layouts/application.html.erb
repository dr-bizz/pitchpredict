<!DOCTYPE html>
<html lang="en" data-theme="pitchpredict">
  <head>
    <title><%= content_for(:title) || "PitchPredict" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="PitchPredict">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0A7B4B">
    <meta name="description" content="Predict every World Cup 2026 score and climb the leaderboard.">

    <%# Turbo 8 page refreshes: morph the DOM and keep scroll position %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Lets client-side code (leaderboard_highlight_controller) know who is
        viewing, so Turbo Stream broadcasts can stay viewer-agnostic. %>
    <% if authenticated? %>
      <meta name="current-user-id" content="<%= Current.user.id %>">
    <% end %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-base-200 text-base-content antialiased">
    <header class="sticky top-0 z-50 hero-gradient text-primary-content shadow-md">
      <div class="navbar mx-auto max-w-5xl px-4 sm:px-6">
        <div class="navbar-start gap-1">
          <% if authenticated? %>
            <%# Mobile hamburger: collapses the nav links into a dropdown menu. %>
            <div class="dropdown lg:hidden">
              <div tabindex="0" role="button" class="btn btn-ghost btn-square text-primary-content" aria-label="Open navigation menu">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </div>
              <ul tabindex="0" class="menu dropdown-content z-50 mt-3 w-52 rounded-box bg-base-100 p-2 text-base-content shadow">
                <li><%= link_to "Dashboard", root_path, class: ("font-semibold text-primary" if current_page?(root_path)) %></li>
                <li><%= link_to "Predictions", predictions_path, class: ("font-semibold text-primary" if current_page?(predictions_path)) %></li>
                <li><%= link_to "Leaderboard", leaderboard_path, class: ("font-semibold text-primary" if current_page?(leaderboard_path)) %></li>
                <% if Current.user&.admin? %>
                  <li><%= link_to "Admin", admin_fixtures_path, class: ("font-semibold text-primary" if request.path.start_with?("/admin")) %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= link_to root_path, class: "btn btn-ghost flex shrink-0 items-center gap-2 px-2 text-primary-content hover:bg-white/10" do %>
            <%= image_tag "icon.svg", alt: "PitchPredict", class: "h-9 w-9 rounded-xl shadow-md" %>
            <span class="hidden text-lg font-bold tracking-tight sm:inline">PitchPredict</span>
          <% end %>

          <% if authenticated? %>
            <ul class="menu menu-horizontal hidden flex-nowrap gap-1 px-1 lg:flex">
              <li><%= link_to "Dashboard", root_path, class: "text-primary-content/90 hover:bg-white/10 hover:text-primary-content #{'bg-white/15 font-semibold text-primary-content' if current_page?(root_path)}" %></li>
              <li><%= link_to "Predictions", predictions_path, class: "text-primary-content/90 hover:bg-white/10 hover:text-primary-content #{'bg-white/15 font-semibold text-primary-content' if current_page?(predictions_path)}" %></li>
              <li><%= link_to "Leaderboard", leaderboard_path, class: "text-primary-content/90 hover:bg-white/10 hover:text-primary-content #{'bg-white/15 font-semibold text-primary-content' if current_page?(leaderboard_path)}" %></li>
              <% if Current.user&.admin? %>
                <li><%= link_to "Admin", admin_fixtures_path, class: "text-primary-content/90 hover:bg-white/10 hover:text-primary-content #{'bg-white/15 font-semibold text-primary-content' if request.path.start_with?('/admin')}" %></li>
              <% end %>
            </ul>
          <% end %>
        </div>

        <div class="navbar-end gap-2">
          <% if authenticated? %>
            <span class="hidden items-center gap-2 md:flex">
              <%# Gold initial avatar: first letter of the signed-in user's name. %>
              <span class="avatar-initial h-8 w-8 bg-gold text-sm text-charcoal" aria-hidden="true"><%= Current.user&.name.to_s.first %></span>
              <span class="text-sm font-semibold text-primary-content"><%= Current.user&.name %></span>
            </span>
            <%= button_to session_path, method: :delete,
                  class: "btn btn-ghost btn-sm gap-1 text-primary-content/90 hover:bg-white/10 hover:text-primary-content" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              <span>Sign out</span>
            <% end %>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "btn btn-ghost btn-sm text-primary-content/90 hover:bg-white/10 hover:text-primary-content" %>
            <%= link_to "Sign up", new_registration_path, class: "btn btn-secondary btn-sm" %>
          <% end %>
        </div>
      </div>
    </header>

    <% if flash.any? %>
      <div class="mx-auto mt-4 max-w-5xl space-y-2 px-4 sm:px-6">
        <% flash.each do |type, message| %>
          <%# Errors must interrupt screen readers (role=alert); notices stay polite. %>
          <div class="alert <%= type.to_s == "alert" ? "alert-error" : "alert-success" %>" role="<%= type.to_s == "alert" ? "alert" : "status" %>">
            <span><%= message %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-8">
      <%= yield %>
    </main>

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker", { scope: "/" });
      }
    </script>
  </body>
</html>
