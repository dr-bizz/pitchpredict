<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "PitchPredict" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="PitchPredict">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0A7B4B">
    <meta name="description" content="Predict every World Cup 2026 score and climb the leaderboard.">

    <%# Turbo 8 page refreshes: morph the DOM and keep scroll position %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-surface text-charcoal antialiased">
    <header class="sticky top-0 z-50 hero-gradient shadow-card">
      <nav class="mx-auto flex max-w-5xl items-center gap-1 px-4 py-2 sm:gap-2 sm:px-6">
        <%= link_to root_path, class: "mr-2 flex shrink-0 items-center gap-2" do %>
          <%= image_tag "icon.svg", alt: "PitchPredict", class: "h-9 w-9 rounded-xl shadow-card" %>
          <span class="hidden text-lg font-bold tracking-tight text-white sm:inline">PitchPredict</span>
        <% end %>

        <% if authenticated? %>
          <%= link_to "Dashboard", root_path, class: current_page?(root_path) ? "nav-link-active" : "nav-link" %>
          <%= link_to "Predictions", predictions_path, class: current_page?(predictions_path) ? "nav-link-active" : "nav-link" %>
          <%= link_to "Leaderboard", leaderboard_path, class: current_page?(leaderboard_path) ? "nav-link-active" : "nav-link" %>
          <% if Current.user&.admin? %>
            <%= link_to "Admin", admin_fixtures_path, class: request.path.start_with?("/admin") ? "nav-link-active" : "nav-link" %>
          <% end %>

          <div class="ml-auto flex items-center gap-2">
            <span class="hidden text-sm font-medium text-white/80 md:inline"><%= Current.user&.name %></span>
            <%= button_to "Sign out", session_path, method: :delete,
                  class: "rounded-lg px-3 py-2 text-sm font-medium text-white/80 hover:bg-white/10 hover:text-white transition-colors cursor-pointer" %>
          </div>
        <% else %>
          <div class="ml-auto flex items-center gap-2">
            <%= link_to "Sign in", new_session_path, class: "nav-link" %>
            <%= link_to "Sign up", new_registration_path, class: "rounded-lg bg-gold px-3 py-2 text-sm font-semibold text-charcoal hover:bg-gold-dark hover:text-white transition-colors" %>
          </div>
        <% end %>
      </nav>
    </header>

    <% if flash.any? %>
      <div class="mx-auto mt-4 max-w-5xl space-y-2 px-4 sm:px-6">
        <% flash.each do |type, message| %>
          <div class="<%= type.to_s == "alert" ? "flash-alert" : "flash-notice" %>" role="status">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-8">
      <%= yield %>
    </main>

    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker", { scope: "/" });
      }
    </script>
  </body>
</html>
